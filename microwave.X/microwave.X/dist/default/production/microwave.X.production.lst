   832     0E97                     init_fetch0:	
   833                           ;	Called with low address in FSR and high address in W
   834                           
   835     0E97  087E               	movf	btemp,w
   836     0E98  008A               	movwf	10
   837     0E99  087F               	movf	btemp+1,w
   838     0E9A  0082               	movwf	2
   839     0E9B                     init_ram0:	
   840                           ;Called with:
   841                           ;	high address of idata address in btemp 
   842                           ;	low address of idata address in btemp+1 
   843                           ;	low address of data in FSR
   844                           ;	high address + 1 of data in btemp-1
   845                           
   846     0E9B  120A  158A  2697  120A  158A  	fcall	init_fetch0
   847     0EA0  0080               	movwf	0
   848     0EA1  0A84               	incf	4,f
   849     0EA2  0804               	movf	4,w
   850     0EA3  067D               	xorwf	btemp+-1,w
   851     0EA4  1903               	btfsc	3,2
   852     0EA5  3400               	retlw	0
   853     0EA6  0AFF               	incf	btemp+1,f
   854     0EA7  1903               	btfsc	3,2
   855     0EA8  0AFE               	incf	btemp,f
   856     0EA9  2E9B               	goto	init_ram0
