   858                           	psect	clrtext
   859     0E3E                     clear_ram0:	
   860                           ;	Called with FSR containing the base address, and
   861                           ;	W with the last address+1
   862                           
   863     0E3E  0064               	clrwdt	;clear the watchdog before getting into this loop
   864     0E3F                     clrloop0:
   865     0E3F  0180               	clrf	0	;clear RAM location pointed to by FSR
   866     0E40  0A84               	incf	4,f	;increment pointer
   867     0E41  0604               	xorwf	4,w	;XOR with final address
   868     0E42  1903               	btfsc	3,2	;have we reached the end yet?
   869     0E43  3400               	retlw	0	;all done for this memory range, return
   870     0E44  0604               	xorwf	4,w	;XOR again to restore value
   871     0E45  2E3F               	goto	clrloop0	;do the next byte
